{
  "manifest_version": 3,
  "name": "3D Model Auto-Downloader",
  "version": "1.0.1",
  "description": "Lädt STL, 3MF und ZIP-Dateien von MakerWorld, Printables und Thingiverse automatisch in sortierte Unterordner.",
  "permissions": [
    "alarms",
    "downloads",
    "offscreen",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://makerworld.com/*",
    "https://*.makerworld.com/*",
    "https://*.bambulab.com/*",
    "https://*.bblmw.com/*",
    "https://printables.com/*",
    "https://*.printables.com/*",
    "https://*.prusa3d.com/*",
    "https://*.amazonaws.com/*",
    "https://www.thingiverse.com/*",
    "https://*.thingiverse.com/*",
    "https://cdn.thingiverse.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.thingiverse.com/*", "https://*.thingiverse.com/*"],
      "js": ["content_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.thingiverse.com/*", "https://*.thingiverse.com/*"],
      "js": ["content_isolated.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "128": "icon_startup.png" }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  }
}
